NODE_ENV=production
PORT=3000

POSTGRES_DB=content_ops
POSTGRES_USER=content_ops
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://content_ops:replace-with-a-long-random-password@db:5432/content_ops?schema=public

AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=https://flowvory.example.com
CRON_SECRET=replace-with-a-separate-long-random-secret
NEXT_PUBLIC_SITE_URL=https://flowvory.example.com
# GitHub Actions populates these for production deploys. Leave them blank for static env files.
APP_VERSION=
APP_RELEASE_ID=
APP_GIT_SHA=
APP_BUILD_TIME=
# Use a hostname on a domain we control. Do not rely on provider-managed fallback domains.
APP_HOST=flowvory.example.com
LETSENCRYPT_EMAIL=ops@example.com

RUN_DB_MIGRATIONS=true
SEED_ON_BOOT=false
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-this-before-any-seed
