VPS_HOST=your-vps-public-hostname-or-ip
VPS_PORT=22
VPS_USER=non-root-admin-user
VPS_APP_DIR=/opt/flowvory
VPS_SSH_PRIVATE_KEY='-----BEGIN OPENSSH PRIVATE KEY-----
replace-this-with-the-private-key-used-by-github-actions
-----END OPENSSH PRIVATE KEY-----'
VPS_SSH_KNOWN_HOSTS='flowvory.example.com ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIreplace-with-your-pinned-host-key'
